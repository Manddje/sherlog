# Keep the build context (and image) free of state, tests and local cruft.
# The Dockerfile copies only the files it needs, but this also speeds builds
# and guarantees no sensitive logs leak into the image.

# Job state / generated reports
/data/
/out/
*_Intune_Logs_Report.html

# NOTE: /testdata/ (anonymised sample logs) intentionally ships in the image
# since the homepage demo button (POST /demo) runs the analysis on it.

# Tests (not needed at runtime)
/tests/
Dockerfile.test
.pytest_cache/

# Python
__pycache__/
*.pyc
.venv/
venv/

# VCS / editor / docs
.git/
.gitignore
*.md
